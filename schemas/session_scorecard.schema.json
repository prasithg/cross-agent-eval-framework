{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-exchange.local/schemas/cross-agent-session-scorecard-v0.3.json",
  "title": "Cross-Agent Work Session Scorecard v0.3",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "session_id", "session_name", "date", "agents", "guardrails", "lanes", "failure_signals", "overall_verdict"],
  "properties": {
    "schema_version": {"const": "0.3"},
    "session_id": {"type": "string", "minLength": 3},
    "session_name": {"type": "string", "minLength": 3},
    "date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "duration_hours": {"type": ["number", "null"], "minimum": 0},
    "agents": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 2}},
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_execution_tools", "gated_actions", "privacy_notes"],
      "properties": {
        "allowed_execution_tools": {"type": "array", "items": {"type": "string"}},
        "gated_actions": {"type": "array", "items": {"type": "string"}},
        "privacy_notes": {"type": "string"}
      }
    },
    "lanes": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/lane"}},
    "objective_scores": {
      "description": "Optional legacy claimed scores. The v0.3 scorer recomputes these and fails strict mode if claims exceed evidence.",
      "type": "object"
    },
    "failure_signals": {"type": "array", "items": {"type": "string"}},
    "overall_verdict": {"enum": ["strong", "useful", "mixed", "weak", "invalid"]},
    "approval_queue": {"type": "array", "items": {"type": "string"}},
    "notes": {"type": "string"}
  },
  "$defs": {
    "lane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lane_id", "name", "artifact_paths", "commands_run", "tests", "git", "deploy_or_live_qa", "handoff_lint", "external_review_delta", "verdict"],
      "properties": {
        "lane_id": {"type": "string"},
        "name": {"type": "string"},
        "artifact_paths": {"type": "array", "items": {"type": "string"}},
        "commands_run": {"type": "array", "items": {"type": "string"}},
        "tests": {
          "type": "object",
          "required": ["status", "assertion_count", "output_summary"],
          "additionalProperties": false,
          "properties": {
            "status": {"enum": ["pass", "fail", "not_run", "not_applicable"]},
            "assertion_count": {"type": "integer", "minimum": 0},
            "output_summary": {"type": "string"}
          }
        },
        "git": {
          "type": "object",
          "required": ["repo_path", "remote_url", "head_sha", "remote_sha_verified"],
          "additionalProperties": false,
          "properties": {
            "repo_path": {"type": ["string", "null"]},
            "remote_url": {"type": ["string", "null"], "pattern": "^(https://github.com/[^\\s]+|git@github.com:[^\\s]+)$"},
            "head_sha": {"type": ["string", "null"], "pattern": "^[0-9a-f]{7,40}$"},
            "remote_sha_verified": {"type": "boolean"}
          }
        },
        "deploy_or_live_qa": {
          "type": "object",
          "required": ["status", "evidence"],
          "additionalProperties": false,
          "properties": {
            "status": {"enum": ["pass", "fail", "not_applicable", "not_attempted"]},
            "evidence": {"type": "string"}
          }
        },
        "handoff_lint": {
          "type": "object",
          "required": ["status", "evidence"],
          "additionalProperties": false,
          "properties": {
            "status": {"enum": ["pass", "fail", "mixed", "not_run", "not_applicable"]},
            "evidence": {"type": "string"}
          }
        },
        "external_review_delta": {"type": "string"},
        "verdict": {"enum": ["shipped", "validated", "drafted", "blocked", "failed"]}
      }
    }
  }
}
